<script id="luxus-sticky-header-js-after">
		(function($){

	    	$(window).scroll(function() {

	    		var brandLogo = 'https://falconedgeproperty.com/wp-content/uploads/2025/12/cropped-WhatsApp_Image_2025-12-11_at_23.49.18_da0ae57a-removebg-preview.png';
				var stickyLogo = 'https://falconedgeproperty.com/wp-content/uploads/2025/12/cropped-WhatsApp-Image-2025-12-11-at-23.49.18_386770fa.jpg';

				var height = $(window).scrollTop();

				// Site Header

				if(height > 300) {
					$('.theme-header').addClass('sticky-top');
					$('.brand-logo').attr('src', stickyLogo);

				} else if (height < 1) {
					$('.theme-header').removeClass('sticky-top');
					$('.brand-logo').attr('src', brandLogo);
				}

			});

	   })(jQuery);
	
//# sourceURL=luxus-sticky-header-js-after
</script>
